# Adzuna (free: https://developer.adzuna.com/) — optional; without it the app uses the committed snapshot
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# LLM providers (free tiers). Groq primary, Gemini fallback.
GROQ_API_KEY=
GOOGLE_API_KEY=

# Langfuse (optional tracing: https://cloud.langfuse.com) — no-op if unset
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
